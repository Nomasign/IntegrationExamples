# ─── SQL Server (docker-compose) ────────────────────────────────────────────
# 12+ chars, must contain upper, lower, digit, symbol.
MSSQL_SA_PASSWORD=ChangeMe_Local_Dev_123!

# ─── Backend (ASP.NET Core) ─────────────────────────────────────────────────
# ASP.NET binds env vars with __ as the key separator. Set these to opt into
# SqlSecretStore (otherwise the demo falls back to InMemorySecretStore).

# SQL Server connection string for the secret store.
# Sql__ConnectionString=Server=localhost,1433;Database=NomaSignDemo;User Id=sa;Password=ChangeMe_Local_Dev_123!;TrustServerCertificate=true;Encrypt=true

# AES-256 master key for envelope encryption. 32 random bytes, base64.
# Generate: openssl rand -base64 32
# In production, supply this from Azure Key Vault / AWS KMS / your secrets manager.
# Sql__MasterKey=REPLACE_WITH_BASE64_32_RANDOM_BYTES
