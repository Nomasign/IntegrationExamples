{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "NomaSign": {
    "BaseUrl": "https://dev.integration.nomasign.com",
    "ClientId": "nomasign-integration",
    // Optional — in the demo we use the UI to pass these interactively so you can see how they work.
    "RefreshToken": "YOUR_REFRESH_TOKEN_HERE",
    // Optional — in the demo we use the UI to pass these interactively so you can see how they work.
    "WebhookSecret": "YOUR_WEBHOOK_SECRET_HERE"
  }
}
